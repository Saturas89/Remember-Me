{
  "name": "storyhold",
  "version": "2.12.0",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:app": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "tsc -b --noEmit && node scripts/check-test-conventions.mjs && node scripts/check-changelog.mjs && node scripts/check-docs-sync.mjs && vitest run",
    "test:coverage": "vitest run --coverage",
    "check:changelog": "node scripts/check-changelog.mjs",
    "check:docs": "node scripts/check-docs-sync.mjs",
    "check:licenses": "node scripts/check-licenses.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "generate-icons": "node scripts/generate-icons.mjs"
  },
  "dependencies": {
    "@azure/msal-browser": "^5.9.0",
    "@react-oauth/google": "^0.13.5",
    "@supabase/supabase-js": "^2.104.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "jszip": "^3.10.1",
    "posthog-js": "^1.373.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "overrides": {
    "@rollup/plugin-terser": "^1.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jszip": "^3.4.0",
    "@types/node": "^24.12.4",
    "@types/react": "^19.1.1",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.6",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.0.2",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.5"
  }
}
