{
  "name": "remember-me",
  "private": true,
  "version": "1.9.1",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && vitest run",
    "build:app": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "tsc -b --noEmit && node scripts/check-test-conventions.mjs && node scripts/check-changelog.mjs && vitest run",
    "check:changelog": "node scripts/check-changelog.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "generate-icons": "node scripts/generate-icons.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.104.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "jszip": "^3.10.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "overrides": {
    "@rollup/plugin-terser": "^1.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/jszip": "^3.4.0",
    "@types/react": "^19.1.1",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.2.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.0.2",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "vite": "^7.3.2",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.5"
  }
}
